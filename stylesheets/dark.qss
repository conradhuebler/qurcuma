/* Dark Mode Stylesheet for Qurcuma */
/* Generated by Claude Code */

/* Main Window & Central Widget */
QMainWindow, QWidget {
    background-color: #1e1e1e;
    color: #e0e0e0;
}

QMainWindow::separator {
    background-color: #2d2d2d;
    width: 3px;
    height: 3px;
}

/* Dialogs & Message Boxes */
QDialog, QMessageBox {
    background-color: #252525;
}

QMessageBox QLabel {
    color: #e0e0e0;
}

/* Menu Bar */
QMenuBar {
    background-color: #252525;
    color: #e0e0e0;
    border-bottom: 1px solid #3d3d3d;
}

QMenuBar::item:selected {
    background-color: #0d47a1;
}

QMenuBar::item:pressed {
    background-color: #1565c0;
}

/* Menus */
QMenu {
    background-color: #252525;
    color: #e0e0e0;
    border: 1px solid #3d3d3d;
}

QMenu::item:selected {
    background-color: #0d47a1;
}

QMenu::item:pressed {
    background-color: #1565c0;
}

QMenu::separator {
    background-color: #3d3d3d;
    height: 1px;
}

/* Status Bar */
QStatusBar {
    background-color: #252525;
    color: #e0e0e0;
    border-top: 1px solid #3d3d3d;
}

QStatusBar::item {
    border: none;
}

/* Buttons */
QPushButton {
    background-color: #0d47a1;
    color: #ffffff;
    border: none;
    border-radius: 4px;
    padding: 6px 12px;
    font-weight: bold;
    font-size: 11px;
}

QPushButton:hover {
    background-color: #1565c0;
}

QPushButton:pressed {
    background-color: #0d47a1;
    padding: 7px 11px;
}

QPushButton:disabled {
    background-color: #424242;
    color: #666666;
}

/* ToolButtons */
QToolButton {
    background-color: transparent;
    color: #e0e0e0;
    border: none;
    border-radius: 2px;
    padding: 4px 8px;
}

QToolButton:hover {
    background-color: #333333;
    border: 1px solid #0d47a1;
}

QToolButton:pressed {
    background-color: #0d47a1;
}

/* Input Fields */
QLineEdit, QTextEdit, QPlainTextEdit {
    background-color: #2d2d2d;
    color: #e0e0e0;
    border: 1px solid #3d3d3d;
    border-radius: 3px;
    padding: 4px 6px;
    selection-background-color: #0d47a1;
    selection-color: #ffffff;
}

QLineEdit:focus, QTextEdit:focus, QPlainTextEdit:focus {
    border: 2px solid #0d47a1;
}

/* ComboBox */
QComboBox {
    background-color: #2d2d2d;
    color: #e0e0e0;
    border: 1px solid #3d3d3d;
    border-radius: 3px;
    padding: 4px 6px;
}

QComboBox:focus {
    border: 2px solid #0d47a1;
}

QComboBox::drop-down {
    border: none;
    width: 20px;
}

QComboBox::down-arrow {
    image: url(:/arrow-down.png);
}

QComboBox QAbstractItemView {
    background-color: #2d2d2d;
    color: #e0e0e0;
    border: 1px solid #3d3d3d;
    selection-background-color: #0d47a1;
}

/* Checkboxes */
QCheckBox {
    color: #e0e0e0;
    spacing: 6px;
}

QCheckBox::indicator {
    width: 18px;
    height: 18px;
}

QCheckBox::indicator:unchecked {
    background-color: #2d2d2d;
    border: 1px solid #3d3d3d;
    border-radius: 2px;
}

QCheckBox::indicator:checked {
    background-color: #0d47a1;
    border: 1px solid #0d47a1;
    border-radius: 2px;
    image: url(:/check.png);
}

QCheckBox::indicator:hover {
    border: 1px solid #0d47a1;
}

/* Spinbox */
QSpinBox, QDoubleSpinBox {
    background-color: #2d2d2d;
    color: #e0e0e0;
    border: 1px solid #3d3d3d;
    border-radius: 3px;
    padding: 3px 5px;
}

QSpinBox:focus, QDoubleSpinBox:focus {
    border: 2px solid #0d47a1;
}

QSpinBox::up-button, QDoubleSpinBox::up-button {
    background-color: #333333;
    border: 1px solid #3d3d3d;
}

QSpinBox::down-button, QDoubleSpinBox::down-button {
    background-color: #333333;
    border: 1px solid #3d3d3d;
}

/* Scrollbar */
QScrollBar:vertical {
    background-color: #1e1e1e;
    width: 12px;
    border: none;
}

QScrollBar::handle:vertical {
    background-color: #555555;
    border-radius: 6px;
    min-height: 20px;
}

QScrollBar::handle:vertical:hover {
    background-color: #666666;
}

QScrollBar:horizontal {
    background-color: #1e1e1e;
    height: 12px;
    border: none;
}

QScrollBar::handle:horizontal {
    background-color: #555555;
    border-radius: 6px;
    min-width: 20px;
}

QScrollBar::handle:horizontal:hover {
    background-color: #666666;
}

QScrollBar::add-line, QScrollBar::sub-line {
    border: none;
    background: none;
}

/* Sliders */
QSlider::groove:horizontal {
    background-color: #3d3d3d;
    border-radius: 3px;
    height: 6px;
}

QSlider::handle:horizontal {
    background-color: #0d47a1;
    border: 1px solid #0d47a1;
    border-radius: 6px;
    width: 18px;
    margin: -6px 0;
}

QSlider::handle:horizontal:hover {
    background-color: #1565c0;
}

/* ProgressBar */
QProgressBar {
    background-color: #2d2d2d;
    border: 1px solid #3d3d3d;
    border-radius: 3px;
    text-align: center;
    color: #e0e0e0;
}

QProgressBar::chunk {
    background-color: #0d47a1;
    border-radius: 2px;
}

/* TabWidget */
QTabWidget::pane {
    border: 1px solid #3d3d3d;
}

QTabBar::tab {
    background-color: #2d2d2d;
    color: #a0a0a0;
    padding: 8px 16px;
    border: 1px solid #3d3d3d;
    border-bottom: none;
    border-top-left-radius: 4px;
    border-top-right-radius: 4px;
}

QTabBar::tab:selected {
    background-color: #1e1e1e;
    color: #e0e0e0;
    border: 1px solid #3d3d3d;
    border-bottom: 3px solid #0d47a1;
    padding-bottom: 5px;
}

QTabBar::tab:hover:!selected {
    background-color: #353535;
    color: #c0c0c0;
}

/* Splitter */
QSplitter::handle {
    background-color: #2d2d2d;
}

QSplitter::handle:hover {
    background-color: #3d3d3d;
}

/* Labels */
QLabel {
    color: #e0e0e0;
}

/* GroupBox */
QGroupBox {
    color: #e0e0e0;
    border: 1px solid #3d3d3d;
    border-radius: 4px;
    padding-top: 12px;
    margin-top: 6px;
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    padding: 0 6px;
}

/* ListView & TreeView */
QListView, QTreeView {
    background-color: #2d2d2d;
    color: #e0e0e0;
    border: 1px solid #3d3d3d;
    gridline-color: #3d3d3d;
    outline: none;
}

QListView::item:selected, QTreeView::item:selected {
    background-color: #0d47a1;
    color: #ffffff;
}

QListView::item:hover, QTreeView::item:hover {
    background-color: #353535;
}

QHeaderView::section {
    background-color: #252525;
    color: #e0e0e0;
    padding: 4px;
    border: 1px solid #3d3d3d;
}

/* ScrollArea */
QScrollArea {
    background-color: #1e1e1e;
}

/* Tooltips */
QToolTip {
    background-color: #2d2d2d;
    color: #e0e0e0;
    border: 1px solid #0d47a1;
    border-radius: 3px;
    padding: 3px 6px;
}

/* ProgressDialog */
QProgressDialog {
    background-color: #252525;
}

/* FileDialog */
QFileDialog {
    background-color: #1e1e1e;
}

QFileDialog QLabel {
    color: #e0e0e0;
}

/* Custom Classes */
ModifiableTextEdit {
    background-color: #2d2d2d;
    color: #e0e0e0;
    border: 1px solid #3d3d3d;
}
