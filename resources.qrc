<RCC>
    <!-- Claude Generated - Visual Polish: Dark mode stylesheet resources -->
    <qresource prefix="/">
    <!--    <file>stylesheets/dark.qss</file>-->
    <!--    <file>stylesheets/light.qss</file>-->
    </qresource>

    <!-- Claude Generated - Phase 3B & 4A: Shader resources for advanced rendering -->
    <qresource prefix="/shaders">
        <!-- SSAO Shaders (Phase 3B - Foundation) -->
        <file>src/shaders/ssao.vert</file>
        <file>src/shaders/ssao.frag</file>
        <file>src/shaders/ssao_blur.frag</file>

        <!-- PBR Shaders (Phase 4A - Cook-Torrance BRDF) -->
        <file>src/shaders/pbr.vert</file>
        <file>src/shaders/pbr.frag</file>

        <!-- Bloom & Post-Processing Shaders (Phase 5B - HDR & Effects) -->
        <file>src/shaders/bloom_bright.frag</file>
        <file>src/shaders/blur_horizontal.frag</file>
        <file>src/shaders/blur_vertical.frag</file>
        <file>src/shaders/bloom_composite.frag</file>
        <file>src/shaders/tonemapping.frag</file>
    </qresource>
</RCC>
